{
  "action": {
    "default_icon": {
      "38": "images/refresh-off-38.png"
    },
    "default_popup": "popup.html",
    "default_title": "Auto Refresh & Save"
  },
  "background": {
    "service_worker": "scripts/background.js"
  },
  "description": "Refresh the current tab on a random interval and download each page snapshot as HTML.",
  "host_permissions": ["http://*/", "https://*/"],
  "icons": {
    "128": "images/easy-auto-refresh-128x128.png",
    "48":  "images/easy-auto-refresh-48x48.png"
  },
  "manifest_version": 3,
  "name": "Auto Refresh & Save",
  "permissions": ["tabs", "storage", "scripting", "alarms", "downloads"],
  "version": "8.0"
}
